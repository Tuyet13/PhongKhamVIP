@{
    Layout = "_Layout";
    ViewData["Title"] = "Đăng Ký Hồ Sơ Thành Viên";
}

<style>
    /* Hiệu ứng rung khi có lỗi */
    .shake {
        animation: shake 0.5s;
    }

    /* Định dạng link chuyển đổi qua lại */
    .login-link {
        color: #008ca3;
        text-decoration: none;
        font-weight: 600;
    }

    .login-link:hover {
        text-decoration: underline;
    }

    /* Đồng bộ nút bấm ẩn/hiện mật khẩu nếu cần sau này */
    .btn-show-pass {
        border-color: #dee2e6 !important;
        color: #008ca3 !important;
    }

    .btn-show-pass:hover {
        background-color: #f8f9fa !important;
    }
</style>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5"> @* Tăng nhẹ độ rộng lên col-md-5 vì form đăng ký nhiều trường thông tin hơn *@
            <div class="card border-0 shadow-sm rounded-4 @(!ViewData.ModelState.IsValid ? "shake" : "")">
                <div class="card-body p-4 text-center">
                    <h4 class="fw-bold mb-2" style="color: #008ca3;">ĐĂNG KÝ TÀI KHOẢN</h4>
                    <p class="text-muted small mb-4">Trở thành thành viên của Hệ thống Phòng Khám VIP để nhận đặc quyền chăm sóc sức khỏe toàn diện.</p>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div class="text-danger small mb-3 text-start" asp-validation-summary="ModelOnly"></div>

                        @* Họ và Tên *@
                        <div class="mb-3 text-start">
                            <label class="small fw-bold text-muted mb-1">Họ và Tên</label>
                            <input type="text" name="fullName" class="form-control py-2" placeholder="Ví dụ: Nguyễn Văn A" style="border-radius: 8px;" required />
                        </div>

                        @* Gmail cá nhân *@
                        <div class="mb-3 text-start">
                            <label class="small fw-bold text-muted mb-1">Gmail cá nhân</label>
                            <input type="email" name="email" class="form-control py-2" placeholder="example@gmail.com" style="border-radius: 8px;" required />
                        </div>

                        @* Số điện thoại *@
                        <div class="mb-3 text-start">
                            <label class="small fw-bold text-muted mb-1">Số điện thoại</label>
                            <input type="tel" name="phoneNumber" class="form-control py-2" placeholder="090xxxxxxx" style="border-radius: 8px;" required />
                        </div>

                        @* Tên đăng nhập *@
                        <div class="mb-3 text-start">
                            <label class="small fw-bold text-muted mb-1">Tên đăng nhập</label>
                            <input type="text" name="username" class="form-control py-2" placeholder="Nhập tên tài khoản..." style="border-radius: 8px;" required />
                        </div>

                        @* Mật khẩu *@
                        <div class="mb-4 text-start">
                            <label class="small fw-bold text-muted mb-1">Mật khẩu</label>
                            <div class="input-group">
                                <input type="password" name="password" id="passRegister" class="form-control py-2" placeholder="Nhập mật khẩu" style="border-top-left-radius: 8px; border-bottom-left-radius: 8px;" required />
                                <button class="btn btn-outline-secondary btn-show-pass" type="button" onclick="togglePass('passRegister', 'iconRegister')" style="border-top-right-radius: 8px; border-bottom-right-radius: 8px;">
                                    <i class="bi bi-eye-slash" id="iconRegister"></i>
                                </button>
                            </div>
                        </div>

                        @* Nút đăng ký *@
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-3" style="background: #008ca3; border:none; border-radius: 8px;">
                            XÁC NHẬN ĐĂNG KÝ
                        </button>

                        @* Link quay lại đăng nhập *@
                        <div class="mt-3">
                            <p class="small mb-0 text-muted">
                                Bạn đã có tài khoản?
                                <a href="/Account/Login" class="login-link">Đăng nhập ngay</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hàm ẩn/hiện mật khẩu đồng bộ với trang Login
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.className = "bi bi-eye";
            } else {
                input.type = "password";
                icon.className = "bi bi-eye-slash";
            }
        }
    </script>
}