@model IEnumerable<PhongKhamVIP.Models.Clinical.Appointment>
@{
    // Thiết lập Layout cho trang
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";
    ViewData["Title"] = "Quản lý lịch hẹn";
}

<div class="container mt-4">
    <h3 class="mb-4">
        <i class="bi bi-calendar-check text-primary"></i> Quản lý lịch hẹn
    </h3>

    <div class="card shadow-sm">
        <div class="card-body">
            <p>Chào mừng bạn đến với hệ thống quản lý lịch khám.</p>
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Bệnh nhân</th>
                        <th>Ngày hẹn</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Patient?.FullName</td>
                                <td>@item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @(item.Status == "CheckedIn" ? "bg-success" : "bg-warning")">
                                        @item.Status
                                    </span>
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <form asp-controller="Receptionist" asp-action="CheckIn" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-info text-white">Check-in</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">Chưa có lịch hẹn nào được tạo.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>