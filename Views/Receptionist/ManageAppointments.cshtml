@using PhongKhamVIP.Models.Clinical
@using PhongKhamVIP.Models.Users
@model IEnumerable<Appointment>

@{
    Layout = "~/Views/Shared/_ReceptionistLayout.cshtml";
    ViewData["Title"] = "Quản lý lịch hẹn";

    // --- FAKE DATA: GIẢ LẬP LỊCH HẸN ---
    var mockAppointments = new List<Appointment>();
    string[] patients = { "Nguyễn Văn An", "Trần Thị Bình", "Lê Minh Chi", "Phạm Văn Dũng" };
    string[] statuses = { "Pending", "CheckedIn" };
    var rand = new Random();

    for (int i = 1; i <= 10; i++)
    {
        mockAppointments.Add(new Appointment
                {
                    Id = i,
                    Patient = new Patient { FullName = patients[rand.Next(patients.Length)] },
                    AppointmentDate = DateTime.Now.AddHours(rand.Next(-2, 5)),
                    Status = statuses[rand.Next(statuses.Length)]
                });
    }

    var displayList = (Model != null && Model.Any()) ? Model : mockAppointments;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold"><i class="bi bi-calendar-check text-primary"></i> Quản lý lịch hẹn</h3>
        <span class="badge bg-secondary">Tổng: @displayList.Count()</span>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Bệnh nhân</th>
                        <th>Ngày hẹn</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in displayList)
                    {
                        <tr>
                            <td class="ps-4">#@item.Id</td>
                            <td class="fw-bold">@item.Patient?.FullName</td>
                            <td>@item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="badge @(item.Status == "CheckedIn" ? "bg-success" : "bg-warning text-dark")">
                                    @(item.Status == "CheckedIn" ? "Đã đến khám" : "Chờ xác nhận")
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.Status == "Pending")
                                {
                                    <form asp-controller="Receptionist" asp-action="CheckIn" asp-route-id="@item.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-info text-white">
                                            <i class="bi bi-check-circle"></i> Check-in
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-check-all"></i></span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>