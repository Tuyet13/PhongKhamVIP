@model PhongKhamVIP.Models.Users.User

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết nhân viên";
}

<style>
    .detail-container {
        max-width: 900px;
        margin: 20px auto;
    }

    .detail-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
    }

    .detail-header {
        display: flex;
        align-items: center;
        margin-bottom: 25px;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
    }

    .avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #0d6efd;
        color: white;
        font-size: 30px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 20px;
    }

    .employee-name {
        font-size: 28px;
        font-weight: 700;
        color: #333;
    }

    .employee-role {
        color: #666;
        margin-top: 5px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 20px;
        margin-top: 20px;
    }

    .info-box {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 10px;
    }

    .info-label {
        color: #6c757d;
        font-size: 13px;
        margin-bottom: 5px;
    }

    .info-value {
        font-size: 16px;
        font-weight: 600;
        color: #212529;
    }

    .role-badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 20px;
        color: white;
        font-weight: 600;
    }

    .doctor {
        background: #198754;
    }

    .receptionist {
        background: #fd7e14;
    }

    .btn-group {
        margin-top: 30px;
    }

    .btn-custom {
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        color: white;
        margin-right: 10px;
    }

    .btn-edit {
        background: #ffc107;
        color: black;
    }

    .btn-back {
        background: #6c757d;
    }
</style>

<div class="detail-container">

    <div class="detail-card">

        <div class="detail-header">

            <div class="avatar">
                @(Model.FullName?.Substring(0, 1).ToUpper())
            </div>

            <div>
                <div class="employee-name">
                    @Model.FullName
                </div>

                <div class="employee-role">
                    Mã nhân viên: #@Model.Id
                </div>
            </div>

        </div>

        <div class="info-grid">

            <div class="info-box">
                <div class="info-label">Tên đăng nhập</div>
                <div class="info-value">@Model.Username</div>
            </div>

            <div class="info-box">
                <div class="info-label">Email</div>
                <div class="info-value">@Model.Email</div>
            </div>

            <div class="info-box">
                <div class="info-label">Số điện thoại</div>
                <div class="info-value">@Model.Phone</div>
            </div>

            <div class="info-box">
                <div class="info-label">Vai trò</div>

                @if (Model.Role == "Doctor")
                {
                    <span class="role-badge doctor">
                        Bác sĩ
                    </span>
                }
                else
                {
                    <span class="role-badge receptionist">
                        Lễ tân
                    </span>
                }
            </div>

            <div class="info-box">
                <div class="info-label">Ngày tạo</div>
                <div class="info-value">
                    @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <div class="info-box">
                <div class="info-label">ID hệ thống</div>
                <div class="info-value">
                    @Model.Id
                </div>
            </div>

        </div>

        <div class="btn-group">

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn-custom btn-edit">
                ✏️ Chỉnh sửa
            </a>

            <a asp-action="Index"
               class="btn-custom btn-back">
                ← Quay lại
            </a>

        </div>

    </div>

</div>