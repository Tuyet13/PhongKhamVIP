@model PhongKhamVIP.Models.Users.User

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa nhân viên";
}

<style>
    .edit-container {
        max-width: 850px;
        margin: 20px auto;
    }

    .edit-card {
        background: #fff;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
    }

    .page-title {
        color: #0d6efd;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 25px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
    }

    .btn-save {
        background: #198754;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
    }

    .btn-back {
        background: #6c757d;
        color: white;
        text-decoration: none;
        padding: 10px 20px;
        border-radius: 8px;
        margin-left: 10px;
    }

    .btn-save:hover {
        opacity: .9;
    }
</style>

<div class="edit-container">

    <div class="edit-card">

        <h2 class="page-title">
            ✏️ Chỉnh sửa nhân viên
        </h2>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="form-row">

                <div class="form-group">
                    <label class="form-label">Họ tên</label>
                    <input asp-for="FullName" class="form-control" />
                </div>

                <div class="form-group">
                    <label class="form-label">Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control" />
                </div>

            </div>

            <div class="form-row">

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>

                <div class="form-group">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" />
                </div>

            </div>

            <div class="form-row">

                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <input asp-for="PasswordHash"
                           class="form-control" />
                </div>

                <div class="form-group">
                    <label class="form-label">Vai trò</label>

                    <select asp-for="Role" class="form-control">
                        <option value="Doctor">Bác sĩ</option>
                        <option value="Receptionist">Lễ tân</option>
                    </select>
                </div>

            </div>

            <button type="submit" class="btn-save">
                💾 Lưu thay đổi
            </button>

            <a asp-action="Index" class="btn-back">
                ← Quay lại
            </a>

        </form>

    </div>

</div>