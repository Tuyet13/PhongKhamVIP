@model PhongKhamVIP.Models.Users.Patient
@{
    ViewData["Title"] = "Xóa bệnh nhân";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <h3 class="text-danger">Bạn có chắc chắn muốn xóa bệnh nhân này?</h3>
    <div class="card p-4 shadow-sm mt-3">
        <h5>Thông tin bệnh nhân:</h5>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Họ và tên</dt>
            <dd class="col-sm-9">@Model.FullName</dd>
            <dt class="col-sm-3">Số điện thoại</dt>
            <dd class="col-sm-9">@Model.Phone</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
        </form>
    </div>
</div>