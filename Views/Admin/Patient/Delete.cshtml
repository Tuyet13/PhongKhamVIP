@model PhongKhamVIP.Models.Users.Patient

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Xóa Hồ Sơ Bệnh Nhân";
}

<div class="container mt-5" style="max-width: 650px;">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-danger text-white py-3 text-center">
            <h5 class="m-0 fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> XÁC NHẬN XÓA HỒ SƠ</h5>
        </div>

        <div class="card-body p-4 text-center">
            <div class="mb-4">
                <i class="bi bi-person-x-fill text-danger" style="font-size: 4rem;"></i>
            </div>

            <h5 class="text-secondary mb-3">Bạn có chắc chắn muốn xóa vĩnh viễn hồ sơ bệnh nhân này?</h5>

            <div class="bg-light p-3 rounded-3 border text-start mb-4">
                <div class="row g-2">
                    <div class="col-4 fw-bold text-muted">Họ và tên:</div>
                    <div class="col-8 fw-bold text-dark">@Model.FullName</div>

                    <div class="col-4 fw-bold text-muted">Số điện thoại:</div>
                    <div class="col-8 text-dark">@Model.Phone</div>

                    <div class="col-4 fw-bold text-muted">Ngày sinh:</div>
                    <div class="col-8 text-dark">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</div>

                    <div class="col-4 fw-bold text-muted">Mã thẻ BHYT:</div>
                    <div class="col-8 text-dark">@(string.IsNullOrEmpty(Model.HealthInsuranceNumber) ? "Không có" : Model.HealthInsuranceNumber)</div>
                </div>
            </div>

            <p class="text-danger small mb-4">
                <i class="bi bi-info-circle"></i> <strong>Lưu ý:</strong> Hành động này không thể hoàn tác. Mọi lịch hẹn hoặc bệnh án liên quan (nếu có) có thể bị ảnh hưởng.
            </p>

            <form action="/Patient/DeleteConfirmed/@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-3">
                    <a href="/Patient" class="btn btn-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left-short"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">
                        <i class="bi bi-trash3-fill"></i> Xác nhận xóa sạch
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>