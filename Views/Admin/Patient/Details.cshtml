@model PhongKhamVIP.Models.Users.Patient
@{
    ViewData["Title"] = "Chi tiết bệnh nhân";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-primary">Thông tin chi tiết bệnh nhân</h3>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Chỉnh sửa</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="text-muted border-bottom pb-2 mb-3">Thông tin hành chính</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Họ và tên</dt>
                        <dd class="col-sm-8 fw-bold">@Model.FullName</dd>

                        <dt class="col-sm-4">Số điện thoại</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4">Ngày sinh</dt>
                        <dd class="col-sm-8">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</dd>

                        <dt class="col-sm-4">Địa chỉ</dt>
                        <dd class="col-sm-8">@Model.Address</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h5 class="text-muted border-bottom pb-2 mb-3">Thông tin tài khoản</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Tên đăng nhập</dt>
                        

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(Model.User?.Email ?? "N/A")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>