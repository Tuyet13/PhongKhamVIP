@model IEnumerable<PhongKhamVIP.Models.Users.Patient>
@{
    ViewData["Title"] = "Quản lý Bệnh nhân";
    Layout = "_AdminLayout"; // Đảm bảo dùng Layout dành cho Admin
}

<div class="container-fluid">
    <h3 class="text-primary mb-4">Danh sách Bệnh nhân</h3>

    <div class="card-custom">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Họ và tên</th>
                    <th>Số điện thoại</th>
                    <th>Ngày sinh</th>
                    <th>Địa chỉ</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Phone</td>
                        <td>@item.DateOfBirth?.ToString("dd/MM/yyyy")</td>
                        <td>@item.Address</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" style="display:inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                                <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>