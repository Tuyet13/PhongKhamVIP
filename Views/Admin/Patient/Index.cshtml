@model IEnumerable<PhongKhamVIP.Models.Users.Patient>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Bệnh Nhân";
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form asp-action="Index" method="get" class="mb-3">
        <div class="input-group" style="max-width: 450px;">
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm theo tên hoặc số điện thoại...">
            <button class="btn btn-primary" type="submit">Tìm</button>
        </div>
    </form>

    <table class="table table-hover">
        <thead class="table-primary">
            <tr>
                <th>Họ tên</th>
                <th>Ngày sinh</th>
                <th>Giới tính</th>
                <th>SĐT</th>
                <th>Tài khoản</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.DateOfBirth?.ToString("dd/MM/yyyy")</td>
                    <td>@item.Gender</td>
                    <td>@item.Phone</td>
                    <td>@(item.User?.Username ?? "Vãng lai")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Xem</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <form asp-action="DeleteConfirmed" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa?');">
                            <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>