@model PhongKhamVIP.Models.Finance.Salary

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi Tiết Bảng Lương";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 max-width: 800px; margin: auto;">
        <div class="card-header bg-info text-white py-3">
            <h5 class="m-0"><i class="bi bi-info-circle-fill"></i> Chi Tiết Bảng Lương Nhân Viên</h5>
        </div>
        <div class="card-body py-4">
            <dl class="row fs-6">
                <dt class="col-sm-4 mb-3 text-muted">Nhân viên:</dt>
                <dd class="col-sm-8 mb-3"><strong>@Model.User?.FullName</strong></dd>

                <dt class="col-sm-4 mb-3 text-muted">Thời gian:</dt>
                <dd class="col-sm-8 mb-3">Tháng @Model.Month / Năm @Model.Year</dd>

                <dt class="col-sm-4 mb-3 text-muted">Lương cơ bản:</dt>
                <dd class="col-sm-8 mb-3">@Convert.ToDecimal(Model.BaseSalary).ToString("N0") VNĐ</dd>

                <dt class="col-sm-4 mb-3 text-muted">Thưởng KPI ca khám:</dt>
                <dd class="col-sm-8 mb-3 text-success">+ @Convert.ToDecimal(Model.Bonus).ToString("N0") VNĐ</dd>

                <dt class="col-sm-4 mb-3 text-muted">Khấu trừ (Đi muộn/Nghỉ):</dt>
                <dd class="col-sm-8 mb-3 text-danger">- @Convert.ToDecimal(Model.Deductions).ToString("N0") VNĐ</dd>

                <hr class="border-lightmy-3" />

                <dt class="col-sm-4 mb-3 text-dark font-weight-bold">Lương thực nhận:</dt>
                <dd class="col-sm-8 mb-3 text-success fs-5"><strong>@Convert.ToDecimal(Model.NetSalary).ToString("N0") VNĐ</strong></dd>

                <dt class="col-sm-4 mb-3 text-muted">Ngày quyết toán:</dt>
                <dd class="col-sm-8 mb-3">@(Model.PaidDate.HasValue ? Model.PaidDate.Value.ToString("dd/MM/yyyy") : "Chưa thực hiện trả lương")</dd>

                <dt class="col-sm-4 mb-3 text-muted">Trạng thái hệ thống:</dt>
                <dd class="col-sm-8 mb-3">
                    @if (Model.Status == "Paid")
                    {
                        <span class="badge bg-primary px-3 py-2 rounded-pill">Đã thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chưa thanh toán</span>
                    }
                </dd>
            </dl>
            <div class="mt-4">
                <a href="/Salary/Index" class="btn btn-secondary px-4 rounded-pill"><i class="bi bi-arrow-left"></i> Quay lại</a>
            </div>
        </div>
    </div>
</div>