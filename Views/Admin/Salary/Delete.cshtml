@model PhongKhamVIP.Models.Finance.Salary

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Xóa Bảng Lương";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 border-top border-danger border-5" style="max-width: 600px; margin: auto;">
        <div class="card-body p-4 text-center">
            <div class="text-danger mb-3" style="font-size: 50px;">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h4 class="card-title text-dark mb-3">Xác Nhận Xóa Bảng Lương?</h4>
            <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa vĩnh viễn dữ liệu tính lương này của nhân viên không? Thao tác này không thể hoàn tác.</p>

            <div class="bg-light p-3 rounded-3 mb-4 text-start">
                <p class="mb-2"><strong>Nhân viên:</strong> @Model.User?.FullName</p>
                <p class="mb-2"><strong>Bảng lương tháng:</strong> @Model.Month/@Model.Year</p>
                <p class="mb-0"><strong>Số tiền thực nhận:</strong> <span class="text-danger font-weight-bold">@Convert.ToDecimal(Model.NetSalary).ToString("N0") VNĐ</span></p>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4 rounded-pill me-2">
                    <i class="bi bi-trash-fill"></i> Đồng ý xóa
                </button>
                <a href="/Salary/Index" class="btn btn-secondary px-4 rounded-pill">
                    <i class="bi bi-x-circle"></i> Hủy bỏ
                </a>
            </form>
        </div>
    </div>
</div>