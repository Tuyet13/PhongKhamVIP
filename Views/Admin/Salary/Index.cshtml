@model IEnumerable<PhongKhamVIP.Models.Finance.Salary>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Danh Sách Lương Nhân Viên";
    int stt = 1;
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="m-0 font-weight-bold text-primary"><i class="bi bi-card-list"></i> Danh Sách Lương</h4>
            <a href="/Salary/Create" class="btn btn-primary rounded-pill px-3"><i class="bi bi-plus-circle"></i> Thêm mới</a>
        </div>
        <div class="card-body">

            <form asp-action="Index" method="get" class="mb-3">
                <div class="input-group" style="max-width: 400px;">
                    <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm tên nhân viên...">
                    <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle border-light">
                    <thead class="text-white" style="background: #0d6efd;">
                        <tr>
                            <th class="text-center" style="width: 80px;">STT</th>
                            <th>Nhân viên</th>
                            <th class="text-center">Tháng/Năm</th>
                            <th class="text-center">Lương thực nhận</th>
                            <th class="text-center">Ngày trả</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center" style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">@(stt++)</td>
                                    <td><strong>@item.User?.FullName</strong></td>
                                    <td class="text-center">@item.Month / @item.Year</td>
                                    <td class="text-center">
                                        <span class="badge bg-success rounded-pill px-3 py-2" style="font-size: 14px;">
                                            @Convert.ToDecimal(item.NetSalary).ToString("N0") VNĐ
                                        </span>
                                    </td>
                                    <td class="text-center" id="paiddate-text-@item.Id">
                                        @(item.PaidDate.HasValue ? item.PaidDate.Value.ToString("dd/MM/yyyy") : "---")
                                    </td>
                                    <td class="text-center">
                                        <div id="status-badge-@item.Id">
                                            @* ĐỒNG BỘ LOGIC: Kiểm tra nếu bằng Paid thì hiện Đã thanh toán, ngược lại (Unpaid/Pending) hiện Chưa thanh toán *@
                                            @if (item.Status == "Paid")
                                            {
                                                <span class="badge bg-primary px-3 py-2 rounded-pill">Đã thanh toán</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chưa thanh toán</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group gap-1">
                                            <a href="/Salary/Details/@item.Id" class="btn btn-info btn-sm text-white" title="Chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            @* Ẩn hoặc disable nút nếu bảng lương này đã được thanh toán *@
                                            <button type="button" class="btn btn-success btn-sm btn-quick-paid" 
                                                    data-id="@item.Id" 
                                                    title="Hoàn thành thanh toán"
                                                    @(item.Status == "Paid" ? "disabled style=opacity:0.5;" : "")>
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <a href="/Salary/Delete/@item.Id" class="btn btn-danger btn-sm" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">Không có dữ liệu bảng lương.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Thêm thẻ này để tự động sinh Token chống lỗi bảo mật của NET Core khi gửi lệnh POST từ Fetch API *@
@Html.AntiForgeryToken()

@section Scripts {
    <script>
        document.querySelectorAll('.btn-quick-paid').forEach(button => {
            button.addEventListener('click', function (e) {
                e.preventDefault();
                let salaryId = this.getAttribute('data-id');
                let clickedButton = this;

                if (confirm('Xác nhận đổi trạng thái bảng lương này sang "Đã thanh toán"?')) {
                    // Lấy mã Token bảo mật tự động trên trang
                    let tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                    let token = tokenElement ? tokenElement.value : '';

                    let formData = new FormData();
                    formData.append('id', salaryId);
                    formData.append('status', 'Paid');
                    if(token) {
                        formData.append('__RequestVerificationToken', token);
                    }

                    fetch('/Salary/UpdateStatusQuick', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (!response.ok) throw new Error('Mạng lỗi hoặc không có quyền thực thi');
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            // 1. Cập nhật Badge trạng thái sang màu xanh (Đã thanh toán)
                            let badgeContainer = document.getElementById(`status-badge-${salaryId}`);
                            if (badgeContainer) {
                                badgeContainer.innerHTML = '<span class="badge bg-primary px-3 py-2 rounded-pill">Đã thanh toán</span>';
                            }

                            // 2. Điền realtime ngày thanh toán vừa nhận từ Server
                            let dateContainer = document.getElementById(`paiddate-text-${salaryId}`);
                            if (dateContainer && data.paidDate) {
                                dateContainer.innerText = data.paidDate;
                            }

                            // 3. Vô hiệu hóa nút bấm tích xanh để tránh bấm nhầm lại lần nữa
                            clickedButton.setAttribute('disabled', 'disabled');
                            clickedButton.style.opacity = '0.5';
                            
                            alert('Cập nhật trạng thái thanh toán lương thành công!');
                        } else {
                            alert(data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Xử lý cập nhật nhanh thất bại! Vui lòng kiểm tra quyền hạn.');
                    });
                }
            });
        });
    </script>
}