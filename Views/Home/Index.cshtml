
<style>
    :root {
        --cyan-primary: #00bcd4;
        --cyan-dark: #00acc1;
        --text-main: #1a202c;
        --text-muted: #5a6a85;
        --bg-light: #f6fcff;
        --white: #ffffff;
        --shadow-soft: 0 20px 40px rgba(0,0,0,0.05);
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-main);
    }

    /* --- HERO SECTION: BỎ VÒNG TRÒN, PHÓNG TO LOGO --- */
    .hero-section {
        padding: 100px 0;
        background: radial-gradient(circle at top right, #e1f5fe 0%, var(--bg-light) 60%);
        overflow: hidden;
    }

    .hero-image {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .logo-hero-container {
        width: 100%;
        max-width: 500px; /* Tăng kích thước tối đa của logo */
        transition: transform 0.5s ease;
    }

        .logo-hero-container:hover {
            transform: scale(1.05); /* Hiệu ứng phóng nhẹ khi di chuột */
        }

        .logo-hero-container img {
            width: 100%;
            height: auto;
            object-fit: contain;
            /* Đổ bóng trực tiếp dưới chân logo để tạo độ sâu thay vì dùng vòng tròn */
            filter: drop-shadow(0 20px 30px rgba(0, 188, 212, 0.2));
        }

    .hero-title {
        font-size: 3.8rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 25px;
    }

    .btn-cyan {
        background-color: var(--cyan-primary);
        color: white !important;
        border-radius: 12px;
        padding: 15px 35px;
        font-weight: 700;
        border: none;
        box-shadow: 0 10px 20px rgba(0, 188, 212, 0.3);
        transition: 0.3s;
    }

        .btn-cyan:hover {
            background-color: var(--cyan-dark);
            transform: translateY(-3px);
        }

    .btn-outline-cyan {
        border: 2px solid var(--cyan-primary);
        color: var(--cyan-primary) !important;
        border-radius: 12px;
        padding: 15px 35px;
        font-weight: 700;
        transition: 0.3s;
    }

    /* --- CÁC PHẦN DƯỚI: LÀM CHO XỊN NHƯ FIGMA --- */

    /* Why Choose Us Card */
    .benefit-card {
        padding: 40px 30px;
        background: white;
        border-radius: 20px;
        box-shadow: var(--shadow-soft);
        text-align: center;
        transition: 0.3s;
        height: 100%;
    }

        .benefit-card:hover {
            transform: translateY(-10px);
        }

    .benefit-icon {
        width: 70px;
        height: 70px;
        line-height: 70px;
        border-radius: 15px;
        font-size: 30px;
        margin: 0 auto 20px;
        color: var(--cyan-primary);
        background: #e0f7fa;
    }

    /* Stats Section */
    .stats-section {
        background: var(--cyan-primary);
        padding: 60px 0;
    }

    .stats-number {
        font-weight: 800;
        font-size: 2.5rem;
    }

    /* Service Cards */
    .service-card-v2 {
        background: white;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: var(--shadow-soft);
        transition: 0.4s;
    }

    .service-top {
        height: 180px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 50px;
        color: white;
    }

    .bg-blue-grad {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }

    .bg-green-grad {
        background: linear-gradient(135deg, #00b09b 0%, #96c93d 100%);
    }

    .bg-purple-grad {
        background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
    }

    .bg-orange-grad {
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
    }

    .service-body {
        padding: 30px;
    }

    /* CTA Section */
    .cta-section {
        background: linear-gradient(rgba(0,188,212,0.9), rgba(0,188,212,0.9)), url('~/imge/hospital-bg.jpg');
        background-size: cover;
        padding: 80px 0;
    }
    /* ... các phần CSS khác giữ nguyên ... */
    .logo-hero-wrapper {
        width: 420px;
        height: 420px;
        border: 20px solid rgba(225, 245, 254, 0.7); /* Viền mờ bao quanh */
        border-radius: 50%;
        background: transparent; /* Đảm bảo không có nền trắng đè lên */
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 15px 50px rgba(0, 188, 212, 0.1);
        overflow: hidden;
    }

        .logo-hero-wrapper img {
            width: 85%;
            height: auto;
            object-fit: contain;
            /* Lệnh này giúp loại bỏ sắc trắng thừa của ảnh để hòa vào nền xanh của Section */
            mix-blend-mode: multiply;
        }
</style>
