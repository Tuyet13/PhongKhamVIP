@using PhongKhamVIP.Models.System
@using PhongKhamVIP.Models.Finance
@model IEnumerable<Notification>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = ViewBag.Layout ?? "~/Views/Shared/_ReceptionistLayout.cshtml";
    ViewData["Title"] = "Thông báo";
}

<div class="container mt-4">
    <h3 class="mb-4"><i class="bi bi-bell-fill text-warning"></i> Thông báo của tôi</h3>

    @if (Model != null && Model.Any())
    {
        <div class="list-group shadow-sm">
            @foreach (var item in Model)
            {
                <div class="list-group-item list-group-item-action @(item.IsRead ? "" : "list-group-item-light fw-bold")">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1">
                            @if (!item.IsRead)
                            {
                                <span class="badge bg-danger rounded-pill">Mới</span>
                            }
                            Thông báo hệ thống
                        </h6>
                        <small class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <p class="mb-1 text-secondary">@item.Message</p>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mt-5">
            <i class="bi bi-check-circle"></i> Hiện tại không có thông báo mới.
        </div>
    }
</div>
<script>
    function markAsRead(id, element) {
        fetch('/Personal/MarkAsRead/' + id, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    // Cập nhật giao diện: bỏ class đậm, bỏ badge "Mới"
                    element.classList.remove('list-group-item-light', 'fw-bold');
                    const badge = element.querySelector('.badge');
                    if (badge) badge.remove();
                }
            });
    }
</script>