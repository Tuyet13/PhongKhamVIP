@using System.Security.Claims
@{
    var patientName = User.Identity?.Name ?? "Bệnh nhân";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AM2T Clinic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --sidebar-bg: #f8fafc;
            --sidebar-border: #e2e8f0;
            --active-color: #0ea5e9;
            --text-main: #334155;
            --text-muted: #64748b;
        }

        body {
            background-color: #f1f5f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .page-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--sidebar-border);
            position: sticky;
            top: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .logo-box {
            padding: 25px;
            text-align: center;
            border-bottom: 1px solid var(--sidebar-border);
            background: linear-gradient(to bottom, #ffffff, #f8fafc);
        }

        .logo-img {
            width: 100px;
            height: 100px;
            border-radius: 20px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            object-fit: cover;
        }

        .nav-link {
            color: var(--text-muted);
            padding: 12px 20px;
            margin: 6px 15px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 15px;
            transition: all 0.2s;
            font-weight: 500;
        }

            .nav-link:hover {
                background: #e2e8f0;
                color: var(--text-main);
            }

            .nav-link.active {
                background: #e0f2fe;
                color: var(--active-color) !important;
            }

        .top-navbar {
            background: white;
            padding: 15px 30px;
            border-bottom: 1px solid var(--sidebar-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .main-content {
            padding: 30px;
        }

        .btn-outline-danger {
            border-color: #fda4af;
            color: #e11d48;
        }

            .btn-outline-danger:hover {
                background: #ffe4e6;
                color: #e11d48;
                border-color: #fda4af;
            }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <nav class="sidebar">
            <div class="logo-box">
                <img src="~/imge/am2t.jpg" alt="Logo" class="logo-img" />
                <div class="mt-3 fw-bold text-dark">Xin chào, @patientName</div>
            </div>

            <div class="nav flex-column mt-3">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PatientDashboard" ? "active" : "")" asp-controller="PatientDashboard" asp-action="Index">
                    <i class="bi bi-house-door"></i> Tổng quan
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PatientDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "MyAppointments" ? "active" : "")" asp-controller="PatientDashboard" asp-action="MyAppointments">
                    <i class="bi bi-calendar-check"></i> Lịch hẹn của tôi
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PatientDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "MyPrescriptions" ? "active" : "")" asp-controller="PatientDashboard" asp-action="MyPrescriptions">
                    <i class="bi bi-prescription"></i> Đơn thuốc
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PatientDashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "MyInvoices" ? "active" : "")" asp-controller="PatientDashboard" asp-action="MyInvoices">
                    <i class="bi bi-receipt"></i> Hóa đơn
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Profile" ? "active" : "")" asp-controller="Profile" asp-action="Index">
                    <i class="bi bi-person-badge"></i> Hồ sơ cá nhân
                </a>
            </div>

            <div class="mt-auto p-4">
                <a class="btn btn-outline-danger w-100" asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-left"></i> Đăng xuất
                </a>
            </div>
        </nav>

        <div class="flex-grow-1">
            <header class="top-navbar">
                <h5 class="mb-0 fw-bold text-dark">@ViewData["Title"]</h5>
                <div class="text-muted small">@DateTime.Now.ToString("dd/MM/yyyy")</div>
            </header>
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    </div>
</body>
</html>